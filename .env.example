# ============================================
# LLM Configuration - 支持多厂商
# ============================================
# 厂商类型: anthropic, openai, azure, company, custom
LLM_PROVIDER=anthropic

# Anthropic Claude (官方) - 推荐
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI / OpenAI 兼容
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4

# Company Gateway (兼容 Anthropic API 的中转站)
# COMPANY_LLM_API_KEY=your_api_key_here
# COMPANY_LLM_BASE_URL=https://your-api-gateway.com
# COMPANY_LLM_MODEL=claude-sonnet-4-6

# Custom LLM (自定义)
# CUSTOM_LLM_BASE_URL=
# CUSTOM_LLM_API_KEY=
# CUSTOM_LLM_MODEL=
# CUSTOM_LLM_HEADERS=  # JSON 格式额外请求头

# ============================================
# Database Configuration - 支持多数据库
# ============================================
# 数据库类型: sqlite, mysql, postgresql, gaussdb, goldendb
DB_TYPE=sqlite

# SQLite
DB_SQLITE_PATH=./codeagent.db

# MySQL / GaussDB / GoldenDB (MySQL 协议兼容)
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_NAME=codeagent
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=

# PostgreSQL / GaussDB (PostgreSQL 协议兼容)
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=codeagent
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=

# 连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# Agent Configuration
# ============================================
MAX_TOOL_ITERATIONS=10
API_TIMEOUT=60
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Security
# ============================================
API_TOKEN=  # Optional: Leave empty to disable authentication
CORS_ORIGINS=["http://localhost:3000"]

# ============================================
# Cache Configuration - 缓存优化
# ============================================
# 启用缓存（推荐：true 可显著提升响应速度）
ENABLE_CACHE=true

# 缓存后端类型: memory（内存）, disk（磁盘）, hybrid（混合）
CACHE_BACKEND=memory

# 缓存 TTL（秒）
TOOL_CACHE_TTL=3600        # 工具结果缓存（默认 1 小时）
LLM_CACHE_TTL=86400        # LLM 响应缓存（默认 1 天）
FILE_CACHE_TTL=7200        # 文件内容缓存（默认 2 小时）

# 内存缓存配置
MEMORY_CACHE_MAX_SIZE=1000  # 最大缓存条目数

# 磁盘缓存配置（当 CACHE_BACKEND=disk 时生效）
DISK_CACHE_PATH=./cache.db
DISK_CACHE_MAX_SIZE=10000

# 缓存大小限制（超过此大小的结果不缓存）
MAX_CACHE_SIZE_BYTES=100000  # 100KB
